# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Meta / Instagram Graph API
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=your-random-secret-for-batch-auth
TOKEN_ENCRYPTION_KEY=your-32byte-hex-key

# Google Business Profile — gbpFetch の 429/503 リトライ回数（省略時 5、最大 8）
# GBP_API_MAX_RETRIES=5
# 検索キーワード月次を何ヶ月分さかのぼって取得するか（省略時 13、最大 36）
# GBP_KEYWORD_MONTHS_BACK=13

# ---------------------------------------------------------------
# バッチ通知 — 正常終了・エラーとも送信（いずれも省略可。セットされたチャンネルのみ）
# ---------------------------------------------------------------

# メール通知 — SMTP（Gmail 等）を使う場合（下記が揃っていれば Resend より優先）
# Gmail: Google アカウント → セキュリティ → 2 段階認証 → アプリ パスワード を発行し SMTP_PASS に設定
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
# 465 の場合は true、587 (STARTTLS) の場合は false
SMTP_SECURE=true
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
NOTIFY_EMAIL_TO=admin@example.com
# 省略時は SMTP_USER と同じ
NOTIFY_EMAIL_FROM=you@gmail.com

# メール通知 (Resend) — SMTP 未設定のときのみ使用。https://resend.com（無料: 3,000通/月）
RESEND_API_KEY=re_xxxxxxxxxxxx

# LINE 通知 (Messaging API) - LINE Developers でチャンネルアクセストークンを発行（無料: 200通/月）
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
LINE_NOTIFY_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Teams 通知 (Incoming Webhook) - Teams チャンネル→ワークフロー→「Webhookで投稿」から URL を取得（無料）
# テナントポリシーで Incoming Webhook が無効の場合はコメントアウト
TEAMS_WEBHOOK_URL=https://xxxx.webhook.office.com/webhookb2/xxxx
