{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": false
  },
  "crons": [
    {
      "path": "/api/internal/batch-queue-worker?limit=15",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/batch/cron-groups/g2",
      "schedule": "0,15,30 2 * * *"
    },
    {
      "path": "/api/batch/cron-groups/g3",
      "schedule": "15,45 3 * * *"
    },
    {
      "path": "/api/batch/cron-groups/g4",
      "schedule": "0,30 4 * * *"
    },
    {
      "path": "/api/batch/cron-groups/g_hourly",
      "schedule": "0,5,10,45 * * * *"
    },
    {
      "path": "/api/batch/cron-groups/g_halfhour",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/batch/cron-groups/g_weekly",
      "schedule": "0,30 6,7 * * 1"
    },
    {
      "path": "/api/batch/cron-groups/g_daily_misc",
      "schedule": "0 0,12,17,21 * * *"
    }
  ]
}
